# football-data.org — gratuit, saison en cours (10 req/min)
FD_API_KEY=votre_cle_ici

# Clé API-Football — obtenir gratuitement sur https://api-sports.io (100 req/jour)
FOOTBALL_API_KEY=

# Clé The Odds API — obtenir gratuitement sur https://the-odds-api.com (500 req/mois)
# Optionnel : uniquement pour les cotes bookmakers
ODDS_API_KEY=

# Clé Balldontlie — obtenir gratuitement sur https://www.balldontlie.io (60 req/min)
BALLDONTLIE_API_KEY=

# Seuil de value (%) pour les alertes
VALUE_THRESHOLD=2

PORT=3001
